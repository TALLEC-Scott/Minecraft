#version 330 core

in vec2 TexCoord;
in vec3 Normal;
in vec3 FragPos;
in float texLayer;
in float ao;

out vec4 FragColor;

uniform vec3 lightPos;
uniform vec3 lightColor;
uniform sampler2DArray ourTexture;
uniform float emissive; // 1.0 = self-lit (sun), 0.0 = normal lighting

void main() {
    vec4 texColor = texture(ourTexture, vec3(TexCoord, texLayer));

    if (emissive > 0.5) {
        FragColor = texColor;
        return;
    }

    vec3 norm = normalize(Normal);

    // Face-direction shading: modulates diffuse only
    float faceBright = 0.8;
    if (norm.y > 0.5) faceBright = 1.0;       // top
    else if (norm.y < -0.5) faceBright = 0.5;  // bottom

    // Diffuse lighting from sun
    vec3 lightDir = normalize(lightPos - FragPos);
    float diff = max(dot(norm, lightDir), 0.0) * faceBright;

    float light = (0.15 + diff * 1.2) * ao;

    FragColor = vec4(texColor.rgb * light * lightColor, texColor.a);
}
